# AI Negotiation System Configuration - Enhanced Human-like Bargaining

# ============================================
# FREE AI PROVIDERS (Recommended)
# ============================================

# GROQ (FREE & FAST - Recommended for production)
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.1-70b-versatile
# Get free API key at: https://console.groq.com
# Models: llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768

# TOGETHER AI (FREE tier available)
# LLM_PROVIDER=together
# LLM_API_KEY=your_together_api_key_here
# LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# Get free API key at: https://api.together.xyz

# HUGGING FACE (FREE)
# LLM_PROVIDER=huggingface
# LLM_API_KEY=your_huggingface_token_here
# LLM_MODEL=meta-llama/Meta-Llama-3-70B-Instruct
# Get free token at: https://huggingface.co/settings/tokens

# ============================================
# PAID AI PROVIDERS
# ============================================

# OpenAI (Paid - $0.15 per 1000 negotiations)
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4o-mini
# Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo

# Anthropic Claude (Paid - $0.25 per 1000 negotiations)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-3-haiku-20240307

# ============================================
# LOCAL/SELF-HOSTED
# ============================================

# Ollama (FREE - Run locally with GPU)
# LLM_PROVIDER=local
# LLM_ENDPOINT=http://localhost:11434/api/generate
# LLM_MODEL=llama2
# Install: https://ollama.ai

# LLM Parameters (Optimized for human-like negotiation)
LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.8
# Higher temperature (0.8) = more creative, human-like responses

# Rate Limiting
NEGOTIATION_RATE_LIMIT=10
# Maximum negotiations per user per hour

# E-commerce Platform Integration
ECOMMERCE_PLATFORM=generic
# Options: shopify, woocommerce, generic

# Shopify Configuration
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# WooCommerce Configuration
WOO_SITE_URL=https://your-site.com
WOO_CONSUMER_KEY=your_consumer_key
WOO_CONSUMER_SECRET=your_consumer_secret
WOO_WEBHOOK_SECRET=your_webhook_secret

# Analytics
ANALYTICS_AGGREGATION_CRON=0 2 * * *
# Daily at 2 AM

# Feature Flags
DEFAULT_ROLLOUT_PERCENTAGE=50
# Default A/B test percentage

# Security
JWT_SECRET=your_jwt_secret_here
WEBHOOK_SIGNATURE_REQUIRED=true

# Monitoring
ENABLE_NEGOTIATION_LOGGING=true
LOG_LEVEL=info
