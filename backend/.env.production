# Production Environment Configuration for DigitalOcean Ubuntu VPS
# Replace placeholder values before deployment

# Server Configuration
PORT=5000
NODE_ENV=production

# PostgreSQL Database (Single Database)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=egura_store
POSTGRES_USER=egura_admin
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_STRONG_RANDOM_STRING_MIN_32_CHARS

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI/LLM Configuration (Optional)
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_api_key_if_needed

# Search Service (Optional - MeiliSearch)
MEILI_MASTER_KEY=your_meilisearch_master_key
MEILI_HOST=http://localhost:7700

# Base URL (Your Domain)
BASE_URL=https://egura.rw

# InTouch Payment Gateway (Rwanda Mobile Money)
INTOUCH_PAY_USERNAME=egura.ltd
INTOUCH_PAY_PASSWORD=45b4+Yv$w\\/3q{2ZYvW
INTOUCH_PAY_MERCHANT_ID=250220000148
INTOUCH_PAY_API_URL=https://www.intouchpay.co.rw/api/requestpayment/

# CORS Origins (Frontend URL)
CORS_ORIGIN=https://egura.rw

# SSL/HTTPS
FORCE_HTTPS=true
